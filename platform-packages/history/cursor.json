    {
      "id": "cursor",
      "platformId": "cursor",
      "version": "1.0.1",
      "apiVersion": 1,
      "minCoreVersion": "1.0.0",
      "displayName": "Cursor",
      "entry": "runtime/index.json",
      "packageMode": "hotUpdate",
      "installKind": "sidecarAdapter",
      "adapter": {
        "protocol": "http-json-v1",
        "entry": "adapter/macos/cockpit-cursor-adapter",
        "macosEntry": "adapter/macos/cockpit-cursor-adapter",
        "windowsEntry": "adapter/windows/cockpit-cursor-adapter.exe",
        "linuxEntry": "adapter/linux/cockpit-cursor-adapter",
        "methods": [
          "health.check",
          "accounts.list",
          "accounts.current",
          "accounts.delete",
          "accounts.deleteMany",
          "accounts.importJson",
          "accounts.importLocal",
          "accounts.addToken",
          "accounts.export",
          "accounts.indexPath",
          "accounts.refresh",
          "accounts.refreshAll",
          "accounts.updateTags",
          "quota.alertPayload",
          "oauth.start",
          "oauth.complete",
          "oauth.cancel",
          "switch.inject",
          "switch.injectDefaultProfile",
          "instances.store.get",
          "instances.store.replace",
          "instance.getDefaults",
          "instance.list",
          "instance.create",
          "instance.update",
          "instance.delete",
          "instance.start",
          "instance.stop",
          "instance.closeAll",
          "instance.openWindow",
          "runtime.detectLaunchPath",
          "runtime.status",
          "runtime.startDefault",
          "runtime.stopDefault",
          "runtime.restartDefault",
          "runtime.focusDefault"
        ]
      },
      "ui": {
        "protocol": "react-remote-esm-v1",
        "entry": "ui/remoteEntry.js",
        "style": "ui/style.css",
        "exports": [
          "mount",
          "unmount"
        ]
      },
      "capabilities": [
        "accounts",
        "oauth",
        "switch",
        "quota",
        "runtime",
        "instances"
      ],
      "changelog": [
        {
          "version": "1.0.1",
          "date": "2026-07-02",
          "notes": [
            "Moved platform-specific settings to each platform settings popover, with General settings opening the matching platform settings entry.",
            "Changed account authorization keep-alive to renew due tokens without running default full account or quota scans.",
            "Changed platform package replacement to uninstall the old package before installing the downloaded package."
          ],
          "locales": {
            "zh-CN": {
              "notes": [
                "各平台专属设置迁移到对应平台设置弹框，通用设置只保留跳转入口。",
                "账号授权保活改为只续期到期 token，不再默认全量扫描账号或配额。",
                "平台包替换改为先卸载旧包，再安装已下载的新包。"
              ]
            },
            "zh-TW": {
              "notes": [
                "各平台專屬設定遷移到對應平台設定彈框，通用設定只保留跳轉入口。",
                "帳號授權保活改為只續期到期 token，不再預設全量掃描帳號或配額。",
                "平台包替換改為先解除安裝舊包，再安裝已下載的新包。"
              ]
            }
          }
        },
        {
          "version": "1.0.0",
          "date": "2026-07-01",
          "notes": [
            "Platform has been split into an independent package and now runs independently from the host application."
          ],
          "locales": {
            "zh-CN": {
              "notes": [
                "平台拆成独立的包独立运行。"
              ]
            },
            "zh-TW": {
              "notes": [
                "平台拆成獨立的包並獨立運行。"
              ]
            }
          }
        }
      ],
      "contributions": {
        "platforms": [
          {
            "id": "cursor",
            "label": "Cursor",
            "labelKey": "nav.cursor",
            "iconKey": "cursor",
