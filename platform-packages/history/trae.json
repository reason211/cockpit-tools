      "version": "1.0.1",
      "apiVersion": 1,
      "minCoreVersion": "1.0.0",
      "displayName": "Trae",
      "entry": "runtime/index.json",
      "packageMode": "hotUpdate",
      "installKind": "sidecarAdapter",
      "adapter": {
        "protocol": "http-json-v1",
        "entry": "adapter/macos/cockpit-trae-adapter",
        "macosEntry": "adapter/macos/cockpit-trae-adapter",
        "windowsEntry": "adapter/windows/cockpit-trae-adapter.exe",
        "linuxEntry": "adapter/linux/cockpit-trae-adapter",
        "methods": [
          "health.check",
          "accounts.list",
          "accounts.current",
          "accounts.delete",
          "accounts.deleteMany",
          "accounts.importJson",
          "accounts.importLocal",
